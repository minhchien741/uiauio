# =============================================
# Bien moi truong — He thong Dat phong ICTU
# Copy file nay thanh .env roi sua lai cac gia tri:
#   cp docker/.env.example docker/.env
# =============================================

# --- Database (SQL Server) ---
# Mat khau phai co it nhat 8 ky tu, gom chu hoa, chu thuong, so va ky tu dac biet
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
DB_NAME=RoomScheduling
DB_PORT=1433

# --- Backend API ---
API_PORT=5114

# --- Frontend ---
FE_PORT=3000

# --- Bao mat ---
# Chuoi bi mat bat ky, cang dai cang tot
JWT_SECRET=your_jwt_secret_change_me

# --- AI (tuy chon, bo trong neu khong dung) ---
GEMINI_API_KEY=

# --- Email SMTP (tuy chon) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
