# =============================================
# Biến môi trường cho Docker Compose
# Copy file này thành .env và điền giá trị thực tế
# =============================================

# Mật khẩu SQL Server SA (phải có ít nhất 8 ký tự, bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt)
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# JWT Secret cho Node.js Proxy (chuỗi bí mật bất kỳ, càng dài càng tốt)
JWT_SECRET=your_jwt_secret_here

# Google Gemini API Key cho Trợ lý ảo AI (để trống nếu không dùng)
GEMINI_API_KEY=
